# ── .NET ─────────────────────────────────────────────────────────────────────
bin/
obj/
/packages/
/_ReSharper.Caches/
riderModule.iml
*.user
.vs/

# ── Python ────────────────────────────────────────────────────────────────────
AI.Brain/.venv/
AI.Brain/__pycache__/
AI.Brain/**/__pycache__/
AI.Brain/**/*.pyc
AI.Brain/**/*.pyo

# Secrets — NON caricare mai
AI.Brain/.env

# ── Node / Next.js ────────────────────────────────────────────────────────────
dashboard-bmo/node_modules/
dashboard-bmo/.next/
dashboard-bmo/.env*.local

# ── Workspace runtime ─────────────────────────────────────────────────────────
# Il DB SQLite è generato a runtime, non va in repo
workspace/bmo_agent.db

# I file creati dall'agente non vanno in repo (opzionale: rimuovi se vuoi tracciarli)
workspace/files/

# ── Dipendenze locali (gestite da start.py) ───────────────────────────────────
# .NET SDK installato localmente da start.py
.dotnet/
# Node.js portable installato localmente da start.py
.node/

# ── Launcher ─────────────────────────────────────────────────────────────────
# Log file di fallback creati da start.py su Linux senza terminale GUI
*.log

# ── AI.Voice ──────────────────────────────────────────────────────────────────
# Virtual environment (ricreato da start.py)
AI.Voice/venv/
AI.Voice/__pycache__/
AI.Voice/**/__pycache__/
AI.Voice/**/*.pyc
AI.Voice/**/*.pyo
# Modelli Piper TTS (scaricati da download_models.py — ~61MB)
AI.Voice/models/
# File di test e log temporanei
AI.Voice/*.wav
AI.Voice/*.log
AI.Voice/server_stdout.txt
AI.Voice/server_stderr.txt

# ── Export / Modelli addestrati ───────────────────────────────────────────────
# I modelli RVC sono troppo grandi per git (~60-200MB).
# Salvali su Google Drive / HuggingFace e copialie manualmente in:
#   export/bmo_rvc_model/bmo_infer.pth   ← modello inferenza
#   export/bmo_rvc_model/bmo.index       ← indice FAISS
export/bmo_rvc_model/*.pth
export/bmo_rvc_model/*.index

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
*.iml
.DS_Store
Thumbs.db
